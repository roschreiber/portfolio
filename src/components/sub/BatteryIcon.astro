---
const { battery } = Astro.props;
const fillWidth = Math.round((Math.min(100, Math.max(0, battery)) / 100) * 16);
const fillColor = "#000000";
const clipId = `battery-clip-${Math.random().toString(36).slice(2)}`;
---

<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <defs>
    <clipPath id={clipId}>
        <rect x="2" y="6" width="16" height="12" rx="2" />
    </clipPath>
  </defs>
  <rect x="2" y={6} width={fillWidth} height="12" fill={fillColor} stroke="none" clip-path={`url(#${clipId})`} />
  <rect x="2" y="6" width="16" height="12" rx="2" />
  <path d="M 22 14 L 22 10" />
</svg>