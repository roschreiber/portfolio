---
import { Image } from "astro:assets";

type Props = {
  slug: string;
  title: string;
  description: string;
  tags: string[];
  image: string;
  date: Date;
  readTime: string;
};

const { slug, title, image, tags, date, readTime } = Astro.props;
let { description } = Astro.props;

const formattedDate = date
  .toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  })
  .toLowerCase();

if (description.length >= 150) {
  description = description.slice(0, 150) + "...";
}
---

<a
  href={`/blog/${slug}`}
  class="blog-slug block rounded-lg border border-[#DCDCDC] bg-[#F7F7F6]/60 px-4 py-3 text-base font-medium text-black no-underline"
>
  <div class="grid grid-cols-[12rem_1fr_auto] gap-3 -mt-2">
    <img
      id="album-art"
      src={image}
      alt="Album Art"
      class="mt-3 rounded-md object-cover"
    />
    <div class="flex flex-col mt-3 gap-0.5">
      <p class="text-sm font-semibold">{title}</p>
      <p class="text-xs mt-px">{description}</p>
      <div class="mt-1 flex flex-wrap gap-1.5">
        {
          tags.map((tag) => (
            <span class="rounded-md bg-black/7.5 px-2 py-1 text-xs leading-none text-black">
              {tag}
            </span>
          ))
        }
      </div>
    </div>

    <div class="mt-3 text-right flex flex-col gap-0.5 items-end text-xs">
      <p>{formattedDate}</p>
      <p class="mt-1">{readTime} read</p>
    </div>
  </div>
</a>
