---

type Props = {
    title: string;
    description: string;
    tags: string[];
    href?: string;
    status: "In Progress" | "Completed";
}

const { title, description, tags, href, status } = Astro.props;

---

<div
  class="rounded-lg border border-[#DCDCDC] bg-[#F7F7F6]/60 px-4 py-3 text-base font-medium"
>
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0">
    <p class="text-xl font-semibold leading-tight">{title}</p>
    <p class="mt-2 leading-tight">{description}</p>
  </div>

  <a href={href} target="_blank" class="shrink-0 rounded-md border border-[#DCDCDC] bg-[#F7F7F6]/60 px-3 py-1 text-xs font-semibold">
    Live <!-- add arrow from animate-ui -->
  </a>
</div>

<div class="mt-3 flex flex-wrap gap-1.5">
  {
    tags.map((tag) => (
        <span class="rounded-md bg-black/7.5 px-2 py-1 text-xs leading-none text-black">{tag}</span>
    ))
  } 
</div>
</div>