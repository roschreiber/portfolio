---
import placeholder from "../assets/imgs/placeholder.png";
import { AudioLinesIcon } from "./animate-ui/AudioLinesIcon";
import { ExternalLinkIcon } from "./animate-ui/ExternalLinkIcon";

const placeholderSrc = placeholder.src;
---

<div
  class="relative w-full max-w-lg h-50 rounded-lg border-2 border-[#DCDCDC] bg-[#F7F7F6]/60 px-4 py-3 text-base font-medium"
>
  <div class="flex w-full items-center justify-between">
    <p id="nowListening" class="flex items-center gap-1.5 text-xs leading-tight">
      <AudioLinesIcon id="audio-icon" className="-mb-0.75"client:load /><span id="nowListeningText" class="font-semibold">now listening on spotify</span>
    </p>
    <div class="flex items-center gap-1 opacity-80 cursor-pointer" id="hrefSpotify">
      <p id="openSpotify" class="text-[10px] leading-tight">view on spotify</p>
      <ExternalLinkIcon id="external-link-icon" className="opacity-80 w-3.5 h-3.5 mb-0.5" client:load />
    </div>
  </div>

  <div class="flex w-full items-center gap-4">
    <img
      id="album-art"
      src={placeholderSrc}
      alt="Album Art"
      class="mt-3 h-36 w-36 rounded-lg object-cover"
    />
    <div class="flex flex-col -translate-y-9 gap-0.5">
      <p id="title" class="text-xs font-bold"></p>
      <p id="artist" class="text-xs"></p>
      <p id="album" class="text-[10px]"></p>
    </div>
  </div>
</div>

<script define:vars={{ placeholderSrc }}>
  async function getSpotify() {
    const discordID = "316991053242564609";
    const response = await fetch(
      `https://api.lanyard.rest/v1/users/${discordID}`,
    ).then((res) => res.json());
    const spotifyData = response.data?.spotify;

    const title = spotifyData?.song || "no song";
    const artist = spotifyData?.artist || "no artist";
    const album = spotifyData?.album || "no album";
    const albumArt = spotifyData?.album_art_url || placeholderSrc;
    const trackID = spotifyData?.track_id || null;

    document.querySelector("#title").textContent = title;
    document.querySelector("#artist").textContent = artist;
    document.querySelector("#album").textContent = album;
    document.querySelector("#album-art").src = albumArt;
    
    document.querySelector("#hrefSpotify").onclick = () => {
    if (trackID) {
        window.open(`https://open.spotify.com/track/${trackID}`, "_blank");
      } else {
        window.open(``, "_blank");
      }
    };

    if (!trackID) {
      document.querySelector("#audio-icon").style.display = "none"; 
      document.querySelector("#external-link-icon").style.display = "none";
      document.querySelector("#openSpotify").textContent = "";
      document.querySelector("#nowListeningText").textContent = "not listening on spotify :(";
    } else {
      document.querySelector("#audio-icon").style.display = "inline-block";
      document.querySelector("#external-link-icon").style.display = "inline-block";
      document.querySelector("#openSpotify").textContent = "view on spotify";
      document.querySelector("#nowListeningText").textContent = "now listening on spotify";
    }

  }

  window.setInterval(getSpotify, 10000);
  getSpotify();
</script>
