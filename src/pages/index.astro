---
import Main from "../layouts/Main.astro";
import Header from "../components/Header.astro";
import SpotifyCard from "../components/SpotifyCard.astro";
import DevicesCard from "../components/DevicesCard.astro";
import ProjectsCard from "../components/ProjectsCard.astro";
import Birthday from "../components/Birthday.astro";
import Footer from "../components/Footer.astro";

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Main>
  <Header />
  <Birthday />
  <p>
    i'm <b>17</b> years old and trying to build cool stuff on the web. i'm still a
    beginner, but hope that some of my projects are useful to others
  </p>
  <div class="relative left-1/2 w-screen max-w-none -translate-x-1/2 px-6 mt-6">
    <div class="portfolio-cards mx-auto">
      <div class="portfolio-card-primary">
		<DevicesCard />
      </div>
      <div class="portfolio-card-secondary">
        <SpotifyCard />
      </div>
    </div>
  </div>
    <div class="relative left-1/2 w-screen max-w-none -translate-x-1/2 px-6 mt-4">
      <ProjectsCard />
    </div>
  <!-- add selector with 2 things, timeline and blog
	 timeline would be a list of projects
	 blog is self-explanatory.
 -->
  <Footer />
  <!-- add footer -->
</Main>
