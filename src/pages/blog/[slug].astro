---
import Main from "../../layouts/Main.astro";
import Birthday from "../../components/Birthday.astro";
import { MessageSquareMoreIcon } from "../../components/animate-ui/MessageSquareMoreIcon.tsx"
import { ArrowLeftIcon } from "../../components/animate-ui/ArrowLeftIcon.tsx"


import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Main>
  <Birthday />
  <p>
    i'm trying to build cool stuff on the web. i'm still a beginner, but hope
    that some of my projects are useful to others
  </p>
  <div
    class="blog-txt-card relative w-full rounded-lg border-2 border-[#DCDCDC] bg-[#F7F7F6]/60 px-4 mt-6 py-3 text-base font-medium"
  >
    <div class="flex w-full items-center justify-between">
    <p id="nowListening" class="flex items-center gap-1.5 text-lg leading-tight">
      <MessageSquareMoreIcon className="-mb-px w-5 h-5"client:load /><span id="nowListeningText" class="font-semibold">{post.data.title}</span>
    </p>
    <a href="../blog">
      <ArrowLeftIcon client:load />
    </a>
  </div>
    <hr class="mt-4 h-px border-0 bg-[#DCDCDC]">
    <div class="mt-4">
      <Content />
    </div>
  </div>
</Main>
